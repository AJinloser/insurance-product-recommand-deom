[Unit]
Description=Insurance Recommendation Demo
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/insurance-product-recommand-demo
EnvironmentFile=/etc/insurance-recommend.env
ExecStart=/opt/insurance-product-recommand-demo/.venv/bin/uvicorn app:app --host 0.0.0.0 --port 18080
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
